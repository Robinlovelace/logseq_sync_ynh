#!/bin/bash

#=================================================
# APP REMOVAL SCRIPT
#=================================================

# Source YunoHost helpers
source /usr/share/yunohost/helpers

#=================================================
# LOAD SETTINGS
#=================================================

app=$YNH_APP_INSTANCE_NAME

domain=$(ynh_app_setting_get --app=$app --key=domain)
path_url=$(ynh_app_setting_get --app=$app --key=path)

#=================================================
# STOP AND REMOVE DOCKER CONTAINER
#=================================================

ynh_print_info --message="Stopping and removing Logseq Sync Server via Docker..."
(cd "/var/www/$app" && docker-compose down)

#=================================================
# REMOVE NGINX CONFIGURATION
#=================================================

ynh_remove_nginx_config

#=================================================
# REMOVE APP DIRECTORY
#=================================================

rm -rf "/var/www/$app"

#=================================================
# UNREGISTER WEB PATH
#=================================================

if [[ -n "$domain" ]]; then
    # Try multiple helper names or direct command
    if type ynh_app_unregister_urls >/dev/null 2>&1; then
        ynh_app_unregister_urls --app=$app --domain=$domain --path_url=$path_url
    elif type ynh_webpath_unregister >/dev/null 2>&1; then
        ynh_webpath_unregister --app=$app --domain=$domain --path_url=$path_url
    else
        yunohost app unregister-url "$app" "$domain" "$path_url" || true
    fi
fi

#=================================================
# END OF SCRIPT
#=================================================

ynh_print_info --message="Removal of $app successful"
